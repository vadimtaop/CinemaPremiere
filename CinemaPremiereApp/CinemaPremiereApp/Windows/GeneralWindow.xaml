<Window x:Class="CinemaPremiereApp.Windows.GeneralWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CinemaPremiereApp.Windows"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        mc:Ignorable="d"
        Title='Кинотеатр "Премьера"'
        MinHeight="720"
        MinWidth="1280"
        Height="720"
        Width="1280"
        Icon="../Images/Logo.png"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <materialDesign:Card Grid.Row="0"
                             Background="{DynamicResource MaterialDesign.Brush.Primary}"
                             Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                             materialDesign:ElevationAssist.Elevation="Dp8">
            <Grid>
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text='Кинотеатр "Премьера"'
                           FontSize="24"/>

                <ToggleButton Name="ThemeToggleButton"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Margin="0 0 20 0"
                              IsChecked="True"
                              materialDesign:ToggleButtonAssist.SwitchTrackOnBackground="{DynamicResource MaterialDesign.Brush.Secondary}"
                              Style="{StaticResource MaterialDesignSwitchToggleButton}"
                              Click="ThemeToggleButtonClick"/>
            </Grid>
        </materialDesign:Card>

        <Frame Grid.Row="1"
               NavigationUIVisibility="Hidden"
               Source="../Pages/AuthPage.xaml"/>
    </Grid>
</Window>
