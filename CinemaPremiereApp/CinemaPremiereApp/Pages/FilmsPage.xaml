<Page x:Class="CinemaPremiereApp.Pages.FilmsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CinemaPremiereApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="670"
      d:DesignWidth="1280"
      Title="Фильмы">
    <Grid>
        <DataGrid Name="FilmsDataGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код"
                                    MinWidth="60"
                                    Width="60"
                                    Binding="{Binding FilmId}"/>
                <DataGridTemplateColumn Header="Постер"
                                        MinWidth="120"
                                        MaxWidth="400"
                                        Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding PosterPath}"
                                   MinHeight="100"
                                   MaxHeight="400"
                                   Margin="0"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Название фильма"
                                    MinWidth="120"
                                    Width="*"
                                    Binding="{Binding Title}"/>
                <DataGridTextColumn Header="Жанр"
                                    MinWidth="120"
                                    Width="200"
                                    Binding="{Binding GenresDisplay}"/>
                <DataGridTextColumn Header="Возрастное ограничение"
                                    MinWidth="120"
                                    Width="190"
                                    Binding="{Binding AgeRatings.Name}"/>
                <DataGridTextColumn Header="Дата выхода"
                                    MinWidth="120"
                                    Width="120"
                                    Binding="{Binding ReleaseDate, StringFormat=dd.MM.yyyy}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
