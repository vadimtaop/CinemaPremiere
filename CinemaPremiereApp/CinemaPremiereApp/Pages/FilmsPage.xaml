<Page x:Class="CinemaPremiereApp.Pages.FilmsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CinemaPremiereApp.Pages"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:classes="clr-namespace:CinemaPremiereApp.Classes"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Background="{DynamicResource MaterialDesignPaper}"
      FontFamily="{materialDesign:MaterialDesignFont}"
      Language="ru-RU"
      mc:Ignorable="d" 
      d:DesignHeight="670"
      d:DesignWidth="1280"
      Title="Фильмы">
    <materialDesign:DialogHost Identifier="FilmsPageDialogHost"
                               Name="MainDialogHost">
        <materialDesign:DialogHost.DialogContent>
            <Border Padding="20"
                    MinWidth="700"
                    MinHeight="400"
                    Background="{DynamicResource MaterialDesignPaper}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Добавление нового фильма"
                               FontSize="20"
                               FontWeight="Bold"
                               Grid.ColumnSpan="2"/>

                    <StackPanel Orientation="Vertical"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="0 0 0 0"
                                Grid.Column="0">
                        <Border Width="215"
                                Height="320"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                CornerRadius="4">
                            <Image Name="PosterPreviewImage"
                                   Stretch="Uniform"
                                   Source="/Images/NoPhoto.png"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <Button Content="Выбрать постер"
                                Margin="0 20 0 0"
                                Click="AddPosterButtonClick"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Width="150"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Center"
                                Margin="0 50 0 0">
                        <TextBox Name="AddTitleTextBox"
                                 FontSize="14"
                                 materialDesign:HintAssist.Hint="Название фильма"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

                        <DatePicker Name="AddReleaseDatePicker"
                                    materialDesign:HintAssist.Hint="Дата выхода"
                                    FontSize="14"
                                    Margin="0 20 0 0"/>

                        <Expander Header="Жанры"
                                  Width="420"
                                  FontSize="14"
                                  Margin="0 10 0 0"
                                  Style="{StaticResource MaterialDesignExpander}">
                            <Grid MaxHeight="185">
                                <ListBox Name="AddGenresListBox"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.CanContentScroll="True"
                                         SelectionMode="Multiple">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                      IsHitTestVisible="False">
                                                <TextBlock Text="{Binding Name}"
                                                           TextWrapping="Wrap"
                                                           FontSize="14"/>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Expander>

                        <ListBox Name="AddAgeRatingsListBox"
                                 Margin="0 10 0 0"
                                 FontSize="14"
                                 HorizontalAlignment="Center"
                                 SelectionMode="Single"
                                 Style="{StaticResource MaterialDesignFilterChipPrimaryListBox}">
                            <ListBoxItem Content="0+"
                                         Tag="0"/>
                            <ListBoxItem Content="6+"
                                         Tag="6"/>
                            <ListBoxItem Content="12+"
                                         Tag="12"/>
                            <ListBoxItem Content="16+"
                                         Tag="16"/>
                            <ListBoxItem Content="18+"
                                         Tag="18"/>
                        </ListBox>



                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0 20 0 0">
                            <Button Content="Отмена"
                                    IsCancel="True"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"/>
                            <Button Content="Сохранить"
                                    Click="SaveFilmButtonClick"
                                    Margin="10 0 0 0"
                                    IsDefault="True"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </materialDesign:DialogHost.DialogContent>
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderThickness="0 0 1 0"
                    BorderBrush="{DynamicResource MaterialDesignDivider}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15 15">
                        <StackPanel Margin="0 0 0 20">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0 0 0 10">
                                <materialDesign:PackIcon Kind="FilterVariant"
                                                         VerticalAlignment="Center"/>
                                <TextBlock Text="Фильтры"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Margin="5 0 0 0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBox Name="SearchTextBox"
                                     Margin="0 0 0 0"
                                     FontSize="14"
                                     TextChanged="SearchTextBoxTextChanged"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     materialDesign:HintAssist.Hint="Название фильма"
                                     materialDesign:HintAssist.HintHorizontalAlignment="Center"
                                     materialDesign:TextFieldAssist.HasClearButton="True"/>

                            <Expander Header="Жанры"
                                      Margin="0 10 0 0"
                                      Style="{StaticResource MaterialDesignExpander}">
                                <ListBox Name="GenresListBox"
                                         FontSize="14"
                                         MaxHeight="250"
                                         SelectionMode="Multiple"
                                         SelectionChanged="GenresListBoxSelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                      IsHitTestVisible="False">
                                                <TextBlock Text="{Binding Name}"
                                                           TextWrapping="Wrap"
                                                           FontSize="14"/>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Expander>

                            <TextBlock Text="Возрастной рейтинг"
                                       Margin="0 15 0 5"
                                       Opacity="0.6"
                                       FontSize="14"
                                       TextAlignment="Center"/>

                            <ListBox Name="AgeRatingsListBox"
                                     HorizontalAlignment="Center"
                                     FontSize="14"
                                     MaxWidth="210"
                                     SelectionMode="Multiple"
                                     SelectionChanged="AgeRatingsListBoxSelectionChanged"
                                     Style="{StaticResource MaterialDesignFilterChipPrimaryListBox}">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <classes:CenteredWrapPanel/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBoxItem Content="0+"
                                             Tag="0"/>
                                <ListBoxItem Content="6+"
                                             Tag="6"/>
                                <ListBoxItem Content="12+"
                                             Tag="12"/>
                                <ListBoxItem Content="16+"
                                             Tag="16"/>
                                <ListBoxItem Content="18+"
                                             Tag="18"/>
                            </ListBox>
                        </StackPanel>

                        <Separator Background="{DynamicResource MaterialDesignDivider}"/>

                        <StackPanel Margin="0 20 0 20">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0 0 0 10">
                                <materialDesign:PackIcon Kind="Settings"
                                                         VerticalAlignment="Center"/>
                                <TextBlock Text="Вид"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Margin="5 0 0 0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <DockPanel LastChildFill="False">
                                <TextBlock Text="Отображать фильмов:"
                                           FontSize="14"
                                           VerticalAlignment="Center"/>

                                <ComboBox Name="PageSizeComboBox"
                                          HorizontalAlignment="Right"
                                          Width="55"
                                          FontSize="13"
                                          Margin="10 0 0 0"
                                          Padding="20 0 0 0"
                                          SelectionChanged="PageSizeComboBoxSelectionChanged"
                                          Style="{StaticResource MaterialDesignComboBox}">
                                    <ComboBoxItem Content="5"
                                                  Tag="5"/>
                                    <ComboBoxItem Content="10"
                                                  Tag="10"
                                                  IsSelected="True"/>
                                    <ComboBoxItem Content="20"
                                                  Tag="20"/>
                                    <ComboBoxItem Content="50"
                                                  Tag="50"/>
                                </ComboBox>
                            </DockPanel>

                            <ComboBox Name="SortComboBox"
                                      materialDesign:HintAssist.Hint="Сортировка"
                                      Margin="0 15 0 0"
                                      FontSize="14"
                                      SelectionChanged="SortComboBoxSelectionChanged"
                                      Style="{StaticResource MaterialDesignComboBox}">
                                <ComboBoxItem Content="Без сортировки"
                                              Tag="0"
                                              IsSelected="True"/>
                                <ComboBoxItem Content="Сначала новые"
                                              Tag="1"/>
                                <ComboBoxItem Content="По названию"
                                              Tag="2"/>
                                <ComboBoxItem Content="Возраст (по возрастанию)"
                                              Tag="3"/>
                            </ComboBox>
                        </StackPanel>

                        <Separator Background="{DynamicResource MaterialDesignDivider}"/>

                        <StackPanel Margin="0 20 0 0">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0 0 0 10">
                                <materialDesign:PackIcon Kind="DatabaseArrowUp"
                                                         VerticalAlignment="Center"/>
                                <TextBlock Text="Данные"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Margin="5 0 0 0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Margin="10 0">
                                <Button ToolTip="Экспорт в Excel"
                                        Click="ExportToExcelButtonClick"
                                        Style="{StaticResource MaterialDesignFlatButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FileExcel"/>
                                        <TextBlock Text="Экспорт в Excel"
                                                   Margin="10 0 0 0"/>
                                    </StackPanel>
                                </Button>
                                <Button ToolTip="Экспорт в CSV"
                                        Click="ExportToCsvButtonClick"
                                        Style="{StaticResource MaterialDesignFlatButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FileCsv"/>
                                        <TextBlock Text="Экспорт в CSV"
                                                   Margin="10 0 0 0"/>
                                    </StackPanel>
                                </Button>
                                <Button ToolTip="Экспорт в JSON"
                                        Click="ExportToJsonButtonClick"
                                        Style="{StaticResource MaterialDesignFlatButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CodeJson"/>
                                        <TextBlock Text="Экспорт в JSON"
                                                   Margin="10 0 0 0"/>
                                    </StackPanel>
                                </Button>
                                <Separator/>
                                <Button ToolTip="Импорт из CSV"
                                        Click="ImportFromCsvButtonClick"
                                        Style="{StaticResource MaterialDesignFlatButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FileImport"/>
                                        <TextBlock Text="Импорт из CSV"
                                                   Margin="10 0 0 0"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <Button Content="Сбросить параметры"
                                Margin="0 10 0 0"
                                Height="30"
                                Click="ResetFiltersButtonClick"
                                Style="{StaticResource MaterialDesignOutlinedButton}"/>
                        
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <Button Margin="0 0 30 10"
                        Grid.Row="0"
                        Panel.ZIndex="10"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Click="AddFilmButtonClick"
                        ToolTip="Добавить фильм"
                        Style="{StaticResource MaterialDesignFloatingActionButton}">
                    <materialDesign:PackIcon Kind="Plus"
                                             Width="24"
                                             Height="24"/>
                </Button>

                <DataGrid Name="FilmsDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Grid.Row="0"
                          SelectionChanged="FilmsDataGridSelectionChanged">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridCell"
                               BasedOn="{StaticResource MaterialDesignDataGridCell}">
                            <Setter Property="FocusVisualStyle"
                                    Value="{x:Null}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="Transparent"/>
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource MaterialDesignBody}"/>
                                    <Setter Property="BorderBrush"
                                            Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridRow"
                               BasedOn="{StaticResource MaterialDesignDataGridRow}">
                            <EventSetter Event="PreviewMouseLeftButtonDown"
                                         Handler="PreviewMouseLeftButtonDownDataGrid"/>
                            <EventSetter Event="PreviewMouseRightButtonDown"
                                         Handler="PreviewMouseRightButtonDownDataGrid"/>
                            <EventSetter Event="MouseEnter"
                                         Handler="MouseEnterDataGrid"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="Transparent"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="{DynamicResource MaterialDesignDivider}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Редактировать"
                                      Click="EditFilmMenuItemButtonClick">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Pencil"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Удалить"
                                      Click="DeleteFilmMenuItemButtonClick">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Delete"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    
                    <DataGrid.Columns>
                        <DataGridTemplateColumn MinWidth="60" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}, Mode=TwoWay}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center">
                                        <CheckBox.LayoutTransform>
                                            <ScaleTransform ScaleX="1.2"
                                                            ScaleY="1.2"/>
                                        </CheckBox.LayoutTransform>
                                    </CheckBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTemplateColumn Header="Постер"
                                                MinWidth="120"
                                                MaxWidth="400"
                                                Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding PosterPath}"
                                           MinHeight="100"
                                           MaxHeight="400"
                                           Margin="0"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Название фильма"
                                            MinWidth="120"
                                            Width="*"
                                            Binding="{Binding Title}"/>
                        <DataGridTextColumn Header="Жанр"
                                            MinWidth="120"
                                            Width="200"
                                            Binding="{Binding GenresDisplay}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Возрастной рейтинг"
                                            MinWidth="120"
                                            Width="190"
                                            Binding="{Binding AgeRatings.Name}"/>
                        <DataGridTextColumn Header="Дата выхода"
                                            MinWidth="150"
                                            Width="150"
                                            Binding="{Binding ReleaseDate, StringFormat=dd MMMM yyyy}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <materialDesign:Card Name="SelectionPanel"
                                     Visibility="Collapsed"
                                     VerticalAlignment="Bottom"
                                     HorizontalAlignment="Center"
                                     Margin="0 0 0 20"
                                     Padding="10 2"
                                     UniformCornerRadius="15"
                                     Background="Transparent"
                                     BorderThickness="1"
                                     BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
                                     Panel.ZIndex="10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Name="SelectionCountTextBlock"
                                   Text="Выбрано: 0"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                        <Button Content="Удалить"
                                Click="DeleteSelectionFilmsButtoncClick"
                                Width="150"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Margin="10 0 0 0"/>
                        <Button Content="Снять выделение"
                                Click="ClearSelectionButtonClick"
                                Width="150"
                                Style="{StaticResource MaterialDesignFlatButton}"/>
                    </StackPanel>
                </materialDesign:Card>

                <StackPanel Name="EmptyStackPanel"
                            Grid.Row="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <materialDesign:PackIcon Kind="SmileySad"
                                             Width="80"
                                             Height="80"
                                             HorizontalAlignment="Center"
                                             Foreground="{DynamicResource MaterialDesignDivider}"/>

                    <TextBlock Text="Упс! Ничего не найдено"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0 10 0 0"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>

                    <TextBlock Text="Попробуйте изменить параметры поиска или фильтры"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Opacity="0.6"/>

                    <Button Content="Сбросить всё"
                            Margin="0 20 0 0"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Click="ResetFiltersButtonClick"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="10"
                        VerticalAlignment="Center"
                        BorderThickness="0 1 0 0"
                        Background="{DynamicResource MaterialDesignPaper}"
                        BorderBrush="{DynamicResource MaterialDesignDivider}">
                    <Grid>
                        <TextBlock Name="CounterTextBlock"
                                   Text="Найдено: 0 из 0"
                                   FontSize="18"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Button Content="&lt;&lt;"
                                    Height="30"
                                    Width="50"
                                    Click="FirstPageButtonClick"
                                    Style="{StaticResource MaterialDesignFlatButton}"/>
                            <Button Content="&lt;"
                                    Height="30"
                                    Width="50"
                                    Click="PrevPageButtonClick"
                                    Style="{StaticResource MaterialDesignFlatButton}"/>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="15 0">
                                <TextBlock Text="Страница"
                                           FontSize="16"
                                           VerticalAlignment="Center"
                                           Margin="0 0 8 0"/>

                                <TextBox Name="PageInputTextBox"
                                         FontSize="16"
                                         Width="30"
                                         TextAlignment="Center"
                                         MaxLength="3"
                                         materialDesign:TextFieldAssist.CharacterCounterVisibility="Collapsed"
                                         materialDesign:TextFieldAssist.HasClearButton="False"
                                         KeyDown="PageInputTextBoxKeyDown"
                                         Text="1"/>

                                <TextBlock Name="PageInfoTextBlock"
                                           FontSize="16"
                                           Text="из 1"
                                           VerticalAlignment="Center"
                                           Margin="8 0 0 0"/>
                            </StackPanel>

                            <Button Content="&gt;"
                                    Height="30"
                                    Width="50"
                                    Click="NextPageButtonClick"
                                    Style="{StaticResource MaterialDesignFlatButton}"/>
                            <Button Content="&gt;&gt;"
                                    Height="30"
                                    Width="50"
                                    Click="LastPageButtonClick"
                                    Style="{StaticResource MaterialDesignFlatButton}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</Page>
