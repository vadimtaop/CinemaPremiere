<Page x:Class="CinemaPremiereApp.Pages.FilmsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CinemaPremiereApp.Pages"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Background="{DynamicResource MaterialDesignPaper}"
      FontFamily="{materialDesign:MaterialDesignFont}"
      mc:Ignorable="d" 
      d:DesignHeight="670"
      d:DesignWidth="1280"
      Title="Фильмы">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                BorderThickness="0 0 1 0"
                Background="{DynamicResource MaterialDesignPaper}"
                BorderBrush="{DynamicResource MaterialDesignDivider}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Orientation="Vertical"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBox Name="SearchTextBox"
                             ToolTip="Логин"
                             FontSize="18"
                             Width="200"
                             TextChanged="SearchTextBoxTextChanged"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             materialDesign:HintAssist.Hint="Поиск по названию"
                             materialDesign:HintAssist.HintHorizontalAlignment="Center"
                             materialDesign:TextFieldAssist.HasClearButton="True">
                    </TextBox>

                    <ListBox Name="AgeRatingsListBox"
                             Margin="0 20 0 0"
                             SelectionMode="Multiple"
                             SelectionChanged="AgeRatingsListBoxSelectionChanged"
                             Style="{StaticResource MaterialDesignFilterChipPrimaryListBox}">
                        <ListBoxItem Content="0+"
                                     Tag="0"/>
                        <ListBoxItem Content="6+"
                                     Tag="6"/>
                        <ListBoxItem Content="12+"
                                     Tag="12"/>
                        <ListBoxItem Content="16+"
                                     Tag="16"/>
                        <ListBoxItem Content="18+"
                                     Tag="18"/>
                    </ListBox>

                    <GroupBox Header="Жанры"
                              Height="300"
                              Width="200"
                              Margin="0 20 0 0"
                              Style="{StaticResource MaterialDesignGroupBox}">
                        <ListBox Name="GenresListBox"
                                 SelectionMode="Multiple"
                                 SelectionChanged="GenresListBoxSelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}"
                                              IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                              IsHitTestVisible="False"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </GroupBox>

                    <TextBlock Text="Отображать фильмов"
                               TextAlignment="Center"
                               Margin="0 20 0 0"/>

                    <ComboBox Name="PageSizeComboBox"
                              Margin="0 5 0 0"
                              Width="60"
                              Padding="5"
                              SelectionChanged="PageSizeComboBoxSelectionChanged"
                              Style="{StaticResource MaterialDesignComboBox}">
                        <ComboBoxItem Content="5"
                                      Tag="5"/>
                        <ComboBoxItem Content="10"
                                      Tag="10"
                                      IsSelected="True"/>
                        <ComboBoxItem Content="20"
                                      Tag="20"/>
                        <ComboBoxItem Content="50"
                                      Tag="50"/>
                    </ComboBox>

                    <TextBlock Text="Сортировка"
                               TextAlignment="Center"
                               Margin="0 20 0 0"/>

                    <ComboBox Name="SortComboBox"
                              materialDesign:HintAssist.Hint="Сортировка"
                              Margin="0 5 0 0"
                              SelectionChanged="SortComboBoxSelectionChanged"
                              Style="{StaticResource MaterialDesignComboBox}">
                        <ComboBoxItem Content="Без сортировки"
                                      Tag="0"
                                      IsSelected="True"/>
                        <ComboBoxItem Content="Сначала новые"
                                      Tag="1"/>
                        <ComboBoxItem Content="По названию (А-Я)"
                                      Tag="2"/>
                        <ComboBoxItem Content="Возраст (по возрастанию)"
                                      Tag="3"/>
                    </ComboBox>

                    <Button Content="Сбросить фильтры"
                            Margin="0 20 0 0"
                            Click="ResetFiltersButtonClick"
                            Style="{StaticResource MaterialDesignOutlinedButton}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <DataGrid Name="FilmsDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Grid.Row="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Код"
                                        MinWidth="60"
                                        Width="60"
                                        Binding="{Binding FilmId}"/>
                    <DataGridTemplateColumn Header="Постер"
                                            MinWidth="120"
                                            MaxWidth="400"
                                            Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding PosterPath}"
                                       MinHeight="100"
                                       MaxHeight="400"
                                       Margin="0"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Название фильма"
                                        MinWidth="120"
                                        Width="*"
                                        Binding="{Binding Title}"/>
                    <DataGridTextColumn Header="Жанр"
                                        MinWidth="120"
                                        Width="200"
                                        Binding="{Binding GenresDisplay}"/>
                    <DataGridTextColumn Header="Возрастное ограничение"
                                        MinWidth="120"
                                        Width="190"
                                        Binding="{Binding AgeRatings.Name}"/>
                    <DataGridTextColumn Header="Дата выхода"
                                        MinWidth="120"
                                        Width="120"
                                        Binding="{Binding ReleaseDate, StringFormat=dd.MM.yyyy}"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Name="EmptyStackPanel"
                        Grid.Row="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                <materialDesign:PackIcon Kind="SmileySad"
                                         Width="80"
                                         Height="80"
                                         HorizontalAlignment="Center"
                                         Foreground="{DynamicResource MaterialDesignDivider}"/>

                <TextBlock Text="Упс! Ничего не найдено"
                           FontSize="24"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0 10 0 0"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>

                <TextBlock Text="Попробуйте изменить параметры поиска или фильтры"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Opacity="0.6"/>

                <Button Content="Сбросить всё"
                        Margin="0 20 0 0"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Click="ResetFiltersButtonClick"/>
            </StackPanel>
            
            <Border Grid.Row="1"
                    Margin="10"
                    VerticalAlignment="Center"
                    BorderThickness="0 1 0 0"
                    Background="{DynamicResource MaterialDesignPaper}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}">
                <Grid>
                    <TextBlock Name="CounterTextBlock"
                               Text="Найдено: 0 из 0"
                               FontSize="18"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Button Content="&lt;&lt;"
                                Height="30"
                                Width="50"
                                Click="FirstPageButtonClick"
                                Style="{StaticResource MaterialDesignFlatButton}"/>
                        <Button Content="&lt;"
                                Height="30"
                                Width="50"
                                Click="PrevPageButtonClick"
                                Style="{StaticResource MaterialDesignFlatButton}"/>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="15 0">
                            <TextBlock Text="Страница"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       Margin="0 0 8 0"/>

                            <TextBox Name="PageInputTextBox"
                                     FontSize="16"
                                     Width="30"
                                     TextAlignment="Center"
                                     MaxLength="3"
                                     materialDesign:TextFieldAssist.CharacterCounterVisibility="Collapsed"
                                     materialDesign:TextFieldAssist.HasClearButton="False"
                                     KeyDown="PageInputTextBoxKeyDown"
                                     Text="1"/>

                            <TextBlock Name="PageInfoTextBlock"
                                       FontSize="16"
                                       Text="из 1"
                                       VerticalAlignment="Center"
                                       Margin="8 0 0 0"/>
                        </StackPanel>

                        <Button Content="&gt;"
                                Height="30"
                                Width="50"
                                Click="NextPageButtonClick"
                                Style="{StaticResource MaterialDesignFlatButton}"/>
                        <Button Content="&gt;&gt;"
                                Height="30"
                                Width="50"
                                Click="LastPageButtonClick"
                                Style="{StaticResource MaterialDesignFlatButton}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
