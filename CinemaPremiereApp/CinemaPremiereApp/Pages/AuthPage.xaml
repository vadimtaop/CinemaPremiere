<Page x:Class="CinemaPremiereApp.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CinemaPremiereApp.Pages"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      Background="{DynamicResource MaterialDesignPaper}"
      FontFamily="{materialDesign:MaterialDesignFont}"
      mc:Ignorable="d" 
      d:DesignHeight="450"
      d:DesignWidth="800"
      Title="AuthPage">

    <Grid>
        <materialDesign:Card HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             UniformCornerRadius="15"
                             Padding="50"
                             materialDesign:ElevationAssist.Elevation="Dp8">
            <StackPanel Orientation="Vertical"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="Авторизация"
                           FontSize="24"
                           HorizontalAlignment="Center"/>

                <TextBox Name="LoginTextBox"
                         Margin="0 40 0 0"
                         ToolTip="Логин"
                         FontSize="18"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         materialDesign:HintAssist.Hint="Логин"
                         materialDesign:TextFieldAssist.LeadingIcon="Account"/>
                <PasswordBox Name="PasswordTextBox"
                             Margin="0 20 0 0"
                             ToolTip="Пароль"
                             FontSize="18"
                             Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                             materialDesign:HintAssist.Hint="Пароль"/>

                <Button Content="Войти"
                        Width="200"
                        Margin="0 40 0 0"
                        Click="LoginButtonClick"
                        Cursor="Hand"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Snackbar Name="MainSnackbar"
                                 MessageQueue="{materialDesign:MessageQueue}"/>
    </Grid>
</Page>
